## Admin Dashboard - Main Template
## Uses modularized components from admin-view module
## URL: /app/admin/Dashboard.vm
## This template uses its own layout (no Default.vm layout)

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - UOB Turbine Portal</title>
    <link rel="stylesheet" href="http://www.w3schools.com/lib/w3.css">
    <link rel="stylesheet" href="http://www.w3schools.com/lib/w3-theme-blue-grey.css">
    <link rel="stylesheet" href="$link.getContextPath()/admin/styles/admin-dashboard.css">
</head>
<body>

<div class="admin-container">
    ## Header Component
    #parse("app/admin/components/Header.vm")

    ## Body: Sidebar + Work Area
    <div class="admin-body">
        ## Sidebar Component
        #parse("app/admin/components/Sidebar.vm")

        ## Work Area
        <div class="admin-workarea" id="workarea">
            ## Contextual Menu Component
            #parse("app/admin/components/ContextualMenu.vm")

            ## User Details Section
            <div class="workarea-section" id="user-details">
                <div class="section-header">
                    <h3>User Details</h3>
                </div>
                #set ($searchId = "user-search")
                #set ($placeholder = "Search users by name, email, or login...")
                #set ($onSearchFunction = "searchUsers()")
                #parse("app/admin/components/SearchBox.vm")
                <div id="user-results">
                    #set ($gridId = "user-grid")
                    #set ($headers = ["User ID", "Login Name", "First Name", "Last Name", "Email", "Actions"])
                    #set ($tbodyId = "user-grid-body")
                    #parse("app/admin/components/ResultsGrid.vm")
                </div>
            </div>

            ## Group Details Section
            <div class="workarea-section" id="group-details">
                <div class="section-header">
                    <h3>Group Details</h3>
                </div>
                #set ($searchId = "group-search")
                #set ($placeholder = "Search groups by name...")
                #set ($onSearchFunction = "searchGroups()")
                #parse("app/admin/components/SearchBox.vm")
                <div id="group-results">
                    #set ($gridId = "group-grid")
                    #set ($headers = ["Group ID", "Group Name", "Actions"])
                    #set ($tbodyId = "group-grid-body")
                    #parse("app/admin/components/ResultsGrid.vm")
                </div>
            </div>

            ## Roles Details Section
            <div class="workarea-section" id="roles-details">
                <div class="section-header">
                    <h3>Roles Details</h3>
                </div>
                #set ($searchId = "role-search")
                #set ($placeholder = "Search roles by name...")
                #set ($onSearchFunction = "searchRoles()")
                #parse("app/admin/components/SearchBox.vm")
                <div id="role-results">
                    #set ($gridId = "role-grid")
                    #set ($headers = ["Role ID", "Role Name", "Actions"])
                    #set ($tbodyId = "role-grid-body")
                    #parse("app/admin/components/ResultsGrid.vm")
                </div>
            </div>

            ## Permission Details Section
            <div class="workarea-section" id="permission-details">
                <div class="section-header">
                    <h3>Permission Details</h3>
                </div>
                #set ($searchId = "permission-search")
                #set ($placeholder = "Search permissions by name...")
                #set ($onSearchFunction = "searchPermissions()")
                #parse("app/admin/components/SearchBox.vm")
                <div id="permission-results">
                    #set ($gridId = "permission-grid")
                    #set ($headers = ["Permission ID", "Permission Name", "Actions"])
                    #set ($tbodyId = "permission-grid-body")
                    #parse("app/admin/components/ResultsGrid.vm")
                </div>
            </div>
        </div>
    </div>
</div>

## Tooltip Window Component
#parse("app/admin/components/TooltipWindow.vm")

<script src="$link.getContextPath()/admin/scripts/admin-dashboard.js"></script>
</body>
</html>
